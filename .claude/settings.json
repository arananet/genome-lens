{
  "mcpServers": {
    "gget": {
      "command": "uvx",
      "args": ["gget-mcp"],
      "env": {}
    },
    "biothings": {
      "command": "uvx",
      "args": ["biothings-mcp"],
      "env": {}
    },
    "opengenes": {
      "command": "uvx",
      "args": ["opengenes-mcp"],
      "env": {}
    },
    "synergy-age": {
      "command": "uvx",
      "args": ["synergy-age-mcp"],
      "env": {}
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-spec-on-commit.sh \"$CLAUDE_TOOL_INPUT_COMMAND\""
          }
        ]
      }
    ]
  }
}
