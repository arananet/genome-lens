# Optional: URL of the Cloudflare Worker that powers the AI explainer.
# Leave unset to disable the AI feature entirely. Set at build time.
# VITE_AI_WORKER_URL="https://genome-lens-ai.<account>.workers.dev"

# Anthropic API key — required for the real agent mesh pipeline (/api/mesh-analyze).
# Set this in Railway environment variables. Without it, the mesh endpoint returns
# an error and the UI shows a "not configured" message; the rest of the app works normally.
# ANTHROPIC_API_KEY="sk-ant-..."

# Cloudflare Workers AI — used by /api/explain, /api/synthesize, /api/phenotype-rank.
# CF_ACCOUNT_ID="..."
# CF_API_TOKEN="..."
